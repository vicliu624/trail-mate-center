<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TrailMateCenter.ViewModels"
        x:Class="TrailMateCenter.Views.OfflineCacheDialog"
        x:DataType="vm:OfflineCacheDialogViewModel"
        Width="620"
        MinWidth="560"
        MinHeight="700"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="{DynamicResource Ui.Dashboard.OfflineCacheDialog.Title}">
  <Window.Styles>
    <Style Selector="CheckBox">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
      <Setter Property="FontSize" Value="13"/>
    </Style>
    <Style Selector="CheckBox /template/ TextBlock#CheckBoxText">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>
    <Style Selector="CheckBox:disabled">
      <Setter Property="Foreground" Value="{DynamicResource TextDim}"/>
      <Setter Property="Opacity" Value="0.85"/>
    </Style>
    <Style Selector="CheckBox:disabled /template/ TextBlock#CheckBoxText">
      <Setter Property="Foreground" Value="{DynamicResource TextDim}"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>
    <Style Selector="TextBlock.sectionHeader">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="13"/>
    </Style>
    <Style Selector="TextBlock.dialogHint">
      <Setter Property="Foreground" Value="{DynamicResource TextDim}"/>
      <Setter Property="FontSize" Value="11"/>
    </Style>
  </Window.Styles>

  <Border Background="{DynamicResource PanelBg}"
          BorderBrush="{DynamicResource PanelBorderStrong}"
          BorderThickness="1"
          CornerRadius="8">
    <ScrollViewer Padding="14"
                  VerticalScrollBarVisibility="Auto"
                  MaxHeight="760">
    <StackPanel Spacing="10">
      <TextBlock Text="{DynamicResource Ui.Dashboard.OfflineCacheDialog.Title}"
                 FontSize="16"
                 FontWeight="Bold"
                 Foreground="{DynamicResource TextPrimary}"/>
      <TextBlock Text="{DynamicResource Ui.Dashboard.OfflineCacheDialog.Hint}"
                 Classes="dialogHint"
                 TextWrapping="Wrap"/>

      <StackPanel Spacing="4">
        <TextBlock Text="{DynamicResource Ui.Dashboard.OfflineCacheDialog.Name}" Foreground="{DynamicResource TextPrimary}"/>
        <TextBox Text="{Binding RegionName, UpdateSourceTrigger=PropertyChanged}"
                 Watermark="{DynamicResource Ui.Dashboard.OfflineCacheRegionName}"/>
      </StackPanel>

      <Border BorderBrush="{DynamicResource PanelBorderStrong}"
              BorderThickness="1"
              CornerRadius="6"
              Padding="8"
              Background="{DynamicResource SurfaceDark}">
        <StackPanel Spacing="6">
          <TextBlock Text="{DynamicResource Ui.Dashboard.OfflineCacheDialog.BaseMaps}"
                     Classes="sectionHeader"/>
          <WrapPanel>
            <CheckBox Content="{DynamicResource Ui.Dashboard.BaseMap.Osm}" IsChecked="{Binding IncludeOsm}" Margin="0,0,12,6"/>
            <CheckBox Content="{DynamicResource Ui.Dashboard.BaseMap.Terrain}" IsChecked="{Binding IncludeTerrain}" Margin="0,0,12,6"/>
            <CheckBox Content="{DynamicResource Ui.Dashboard.BaseMap.Satellite}" IsChecked="{Binding IncludeSatellite}" Margin="0,0,12,6"/>
          </WrapPanel>
        </StackPanel>
      </Border>

      <Border BorderBrush="{DynamicResource PanelBorderStrong}"
              BorderThickness="1"
              CornerRadius="6"
              Padding="8"
              Background="{DynamicResource SurfaceDark}">
        <StackPanel Spacing="6">
          <TextBlock Text="{DynamicResource Ui.Dashboard.OfflineCacheDialog.Contours}"
                     Classes="sectionHeader"/>
          <CheckBox Content="{DynamicResource Ui.Dashboard.ContoursLabel}" IsChecked="{Binding IncludeContours}"/>
          <CheckBox Content="{DynamicResource Ui.Config.ContoursFine5m}"
                    IsChecked="{Binding IncludeUltraFineContours}"
                    IsEnabled="{Binding IncludeContours}"/>
        </StackPanel>
      </Border>

      <Border BorderBrush="{DynamicResource PanelBorderStrong}"
              BorderThickness="1"
              CornerRadius="6"
              Padding="8"
              Background="{DynamicResource SurfaceDark}">
        <StackPanel Spacing="6">
          <TextBlock Text="{DynamicResource Ui.Dashboard.OfflineCacheDialog.ZoomRange}"
                     Classes="sectionHeader"/>
          <Grid ColumnDefinitions="*,*"
                RowDefinitions="Auto,Auto"
                ColumnSpacing="10"
                RowSpacing="4">
            <TextBlock Text="{DynamicResource Ui.Dashboard.OfflineCacheDialog.MinZoom}"
                       Foreground="{DynamicResource TextPrimary}"/>
            <TextBlock Grid.Column="1"
                       Text="{DynamicResource Ui.Dashboard.OfflineCacheDialog.MaxZoom}"
                       Foreground="{DynamicResource TextPrimary}"/>
            <ComboBox Grid.Row="1"
                      ItemsSource="{Binding AvailableZoomLevels}"
                      SelectedItem="{Binding MinimumZoom}"
                      MinWidth="120"/>
            <ComboBox Grid.Row="1"
                      Grid.Column="1"
                      ItemsSource="{Binding AvailableZoomLevels}"
                      SelectedItem="{Binding MaximumZoom}"
                      MinWidth="120"/>
          </Grid>
          <TextBlock Text="{DynamicResource Ui.Dashboard.OfflineCacheDialog.ZoomHint}"
                     Classes="dialogHint"
                     TextWrapping="Wrap"/>
        </StackPanel>
      </Border>

      <Border BorderBrush="{DynamicResource PanelBorderStrong}"
              BorderThickness="1"
              CornerRadius="6"
              Padding="8"
              Background="{DynamicResource SurfaceDark}">
        <StackPanel Spacing="8">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="{DynamicResource Ui.Dashboard.OfflineCacheDialog.Poi}"
                       Classes="sectionHeader"/>
            <CheckBox Grid.Column="1"
                      Content="{DynamicResource Ui.Dashboard.OfflineCacheDialog.PoiEnable}"
                      IsChecked="{Binding EnablePoiSeparation}"/>
          </Grid>

          <Grid ColumnDefinitions="*,Auto"
                ColumnSpacing="8"
                IsEnabled="{Binding EnablePoiSeparation}">
            <TextBox Text="{Binding PoiPbfPath, UpdateSourceTrigger=PropertyChanged}"
                     Watermark="{DynamicResource Ui.Dashboard.OfflineCacheDialog.PoiPbfPath}"/>
            <Button Grid.Column="1"
                    Content="{DynamicResource Ui.Dashboard.OfflineCacheDialog.PoiPickPbf}"
                    Click="OnPickPbfClicked"/>
          </Grid>

          <WrapPanel IsEnabled="{Binding EnablePoiSeparation}">
            <CheckBox Content="{DynamicResource Ui.Dashboard.OfflineCacheDialog.PoiFullJsonl}"
                      IsChecked="{Binding GenerateFullPoisJsonl}"
                      Margin="0,0,12,6"/>
            <CheckBox Content="{DynamicResource Ui.Dashboard.OfflineCacheDialog.PoiTileIndex}"
                      IsChecked="{Binding GenerateTileIndexedPoiFiles}"
                      Margin="0,0,12,6"/>
            <CheckBox Content="{DynamicResource Ui.Dashboard.OfflineCacheDialog.PoiLabels}"
                      IsChecked="{Binding IncludePoiLabels}"
                      Margin="0,0,12,6"/>
            <CheckBox Content="{DynamicResource Ui.Dashboard.OfflineCacheDialog.PoiTags}"
                      IsChecked="{Binding IncludeOriginalOsmTags}"
                      Margin="0,0,12,6"/>
          </WrapPanel>

          <Grid ColumnDefinitions="*,*,*"
                RowDefinitions="Auto,Auto"
                ColumnSpacing="10"
                RowSpacing="4"
                IsEnabled="{Binding EnablePoiSeparation}">
            <TextBlock Text="{DynamicResource Ui.Dashboard.OfflineCacheDialog.PoiMinZoom}"
                       Foreground="{DynamicResource TextPrimary}"/>
            <TextBlock Grid.Column="1"
                       Text="{DynamicResource Ui.Dashboard.OfflineCacheDialog.PoiMaxZoom}"
                       Foreground="{DynamicResource TextPrimary}"/>
            <TextBlock Grid.Column="2"
                       Text="{DynamicResource Ui.Dashboard.OfflineCacheDialog.PoiMaxPerTile}"
                       Foreground="{DynamicResource TextPrimary}"/>
            <ComboBox Grid.Row="1"
                      ItemsSource="{Binding AvailablePoiZoomLevels}"
                      SelectedItem="{Binding PoiIndexMinimumZoom}"
                      MinWidth="110"/>
            <ComboBox Grid.Row="1"
                      Grid.Column="1"
                      ItemsSource="{Binding AvailablePoiZoomLevels}"
                      SelectedItem="{Binding PoiIndexMaximumZoom}"
                      MinWidth="110"/>
            <NumericUpDown Grid.Row="1"
                           Grid.Column="2"
                           Minimum="1"
                           Maximum="5000"
                           Increment="25"
                           Value="{Binding MaxPoiPerTile}"
                           MinWidth="110"/>
          </Grid>

          <Grid ColumnDefinitions="Auto,*"
                ColumnSpacing="8"
                IsEnabled="{Binding EnablePoiSeparation}">
            <TextBlock Text="{DynamicResource Ui.Dashboard.OfflineCacheDialog.PoiOutputFormat}"
                       Foreground="{DynamicResource TextPrimary}"
                       VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding AvailablePoiOutputFormats}"
                      SelectedItem="{Binding PoiOutputFormat}"
                      MinWidth="160"/>
          </Grid>

          <ItemsControl ItemsSource="{Binding PoiTypes}"
                        IsEnabled="{Binding EnablePoiSeparation}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:PoiTypeOptionViewModel">
                <CheckBox Content="{Binding Label}"
                          IsChecked="{Binding IsSelected}"
                          Margin="0,0,12,6"/>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <TextBlock Text="{DynamicResource Ui.Dashboard.OfflineCacheDialog.PoiHint}"
                     Classes="dialogHint"
                     TextWrapping="Wrap"/>
        </StackPanel>
      </Border>

      <CheckBox Content="{DynamicResource Ui.Dashboard.OfflineCacheDialog.SaveRegion}"
                IsChecked="{Binding SaveRegion}"/>

      <Border BorderBrush="{DynamicResource PanelBorder}" BorderThickness="0,1,0,0" Padding="0,10,0,0">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
          <Button Content="{DynamicResource Ui.Dashboard.OfflineCacheDialog.Cancel}" Click="OnCancelClicked"/>
          <Button Content="{DynamicResource Ui.Dashboard.OfflineCacheDialog.SaveOnly}" Click="OnSaveOnlyClicked"/>
          <Button Content="{DynamicResource Ui.Dashboard.OfflineCacheDialog.Build}"
                  Classes="primary"
                  IsEnabled="{Binding CanBuild}"
                  Click="OnBuildClicked"/>
        </StackPanel>
      </Border>
    </StackPanel>
    </ScrollViewer>
  </Border>
</Window>
