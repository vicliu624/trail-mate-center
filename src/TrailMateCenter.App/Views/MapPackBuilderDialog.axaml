<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TrailMateCenter.ViewModels"
        x:Class="TrailMateCenter.Views.MapPackBuilderDialog"
        x:DataType="vm:MapPackBuilderViewModel"
        Width="860"
        MinWidth="780"
        MinHeight="760"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        Title="{DynamicResource Ui.MapPack.Title}">
  <Window.Styles>
    <Style Selector="TextBlock.sectionHeader">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="13"/>
    </Style>
    <Style Selector="TextBlock.dialogHint">
      <Setter Property="Foreground" Value="{DynamicResource TextDim}"/>
      <Setter Property="FontSize" Value="11"/>
    </Style>
    <Style Selector="CheckBox">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>
    <Style Selector="CheckBox /template/ TextBlock#CheckBoxText">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>
    <Style Selector="CheckBox:disabled">
      <Setter Property="Foreground" Value="{DynamicResource TextDim}"/>
      <Setter Property="Opacity" Value="0.85"/>
    </Style>
    <Style Selector="CheckBox:disabled /template/ TextBlock#CheckBoxText">
      <Setter Property="Foreground" Value="{DynamicResource TextDim}"/>
      <Setter Property="Opacity" Value="1"/>
    </Style>
  </Window.Styles>

  <Border Background="{DynamicResource PanelBg}"
          BorderBrush="{DynamicResource PanelBorderStrong}"
          BorderThickness="1"
          CornerRadius="8">
    <Grid RowDefinitions="Auto,*,Auto" Margin="14">
      <StackPanel Spacing="4">
        <TextBlock Text="{DynamicResource Ui.MapPack.Title}"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimary}"/>
        <TextBlock Text="{DynamicResource Ui.MapPack.Description}"
                   Classes="dialogHint"
                   TextWrapping="Wrap"/>
      </StackPanel>

      <ScrollViewer Grid.Row="1"
                    Margin="0,12,0,10"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="10">
          <Border BorderBrush="{DynamicResource PanelBorderStrong}" BorderThickness="1" CornerRadius="6" Padding="10" Background="{DynamicResource SurfaceDark}">
            <StackPanel Spacing="8">
              <TextBlock Text="{DynamicResource Ui.MapPack.Step.Area}" Classes="sectionHeader"/>
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox Text="{Binding AreaSearchText, UpdateSourceTrigger=PropertyChanged}"
                         Watermark="{DynamicResource Ui.MapPack.AreaSearchWatermark}"/>
                <Button Grid.Column="1"
                        Content="{DynamicResource Ui.MapPack.SearchAdminBoundary}"
                        Command="{Binding SearchAdminAreasCommand}"/>
              </Grid>
              <ListBox ItemsSource="{Binding AdminAreas}"
                       SelectedItem="{Binding SelectedAdminArea}"
                       Height="90"
                       Background="{DynamicResource PanelBg2}"
                       BorderBrush="{DynamicResource PanelBorder}"
                       BorderThickness="1">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:AdminAreaOptionViewModel">
                    <StackPanel Spacing="2" Margin="4">
                      <TextBlock Text="{Binding DisplayText}" Foreground="{DynamicResource TextPrimary}"/>
                      <TextBlock Text="{Binding DetailText}" Foreground="{DynamicResource TextDim}" FontSize="10"/>
                    </StackPanel>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>

              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <StackPanel Spacing="2">
                  <TextBlock Text="{DynamicResource Ui.MapPack.PbfSourceTitle}"
                             Foreground="{DynamicResource TextPrimary}"
                             FontWeight="SemiBold"/>
                  <TextBlock Text="{DynamicResource Ui.MapPack.PbfSourceHint}"
                             Classes="dialogHint"
                             TextWrapping="Wrap"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="{DynamicResource Ui.MapPack.RefreshPbfSource}"
                        Command="{Binding SearchGeofabrikCommand}"/>
              </Grid>
              <ListBox ItemsSource="{Binding GeofabrikRegions}"
                       SelectedItem="{Binding SelectedGeofabrikRegion}"
                       Height="90"
                       Background="{DynamicResource PanelBg2}"
                       BorderBrush="{DynamicResource PanelBorder}"
                       BorderThickness="1">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:GeofabrikRegionOptionViewModel">
                    <StackPanel Spacing="2" Margin="4">
                      <TextBlock Text="{Binding DisplayText}" Foreground="{DynamicResource TextPrimary}"/>
                      <TextBlock Text="{Binding DetailText}" Foreground="{DynamicResource TextDim}" FontSize="10"/>
                    </StackPanel>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="{DynamicResource Ui.MapPack.DownloadSelectedPbf}"
                        Command="{Binding DownloadSelectedPbfCommand}"/>
                <Button Content="{DynamicResource Ui.MapPack.ImportGeoJsonBoundary}"
                        Click="OnImportBoundaryClicked"/>
              </StackPanel>

              <Grid ColumnDefinitions="*,Auto,*,Auto,*,Auto,*" ColumnSpacing="6" RowDefinitions="Auto,Auto,Auto">
                <TextBlock Text="{DynamicResource Ui.MapPack.AreaName}" Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock Grid.Column="2" Text="{DynamicResource Ui.MapPack.AdminLevel}" Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock Grid.Column="4" Text="{DynamicResource Ui.MapPack.Bounds}" Foreground="{DynamicResource TextPrimary}"/>
                <TextBox Grid.Row="1" Text="{Binding AreaName, UpdateSourceTrigger=PropertyChanged}"/>
                <Border Grid.Row="1"
                        Grid.Column="2"
                        MinWidth="70"
                        MinHeight="32"
                        Padding="8,0"
                        Background="{DynamicResource SurfaceDark}"
                        BorderBrush="{DynamicResource PanelBorder}"
                        BorderThickness="1"
                        CornerRadius="3">
                  <TextBlock Text="{Binding AdminLevelText}"
                             Foreground="{DynamicResource TextPrimary}"
                             VerticalAlignment="Center"/>
                </Border>
                <TextBlock Grid.Row="1" Grid.Column="4" Grid.ColumnSpan="3" Text="{Binding BoundsText}" Foreground="{DynamicResource TextDim}" VerticalAlignment="Center"/>
              </Grid>

              <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="4">
                <TextBlock Text="{DynamicResource Ui.MapPack.West}" Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock Grid.Column="1" Text="{DynamicResource Ui.MapPack.South}" Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock Grid.Column="2" Text="{DynamicResource Ui.MapPack.East}" Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock Grid.Column="3" Text="{DynamicResource Ui.MapPack.North}" Foreground="{DynamicResource TextPrimary}"/>
                <NumericUpDown Grid.Row="1" Minimum="-180" Maximum="180" Increment="0.1" Value="{Binding West}"/>
                <NumericUpDown Grid.Row="1" Grid.Column="1" Minimum="-85" Maximum="85" Increment="0.1" Value="{Binding South}"/>
                <NumericUpDown Grid.Row="1" Grid.Column="2" Minimum="-180" Maximum="180" Increment="0.1" Value="{Binding East}"/>
                <NumericUpDown Grid.Row="1" Grid.Column="3" Minimum="-85" Maximum="85" Increment="0.1" Value="{Binding North}"/>
              </Grid>
              <Button Content="{DynamicResource Ui.MapPack.ApplyBounds}" HorizontalAlignment="Left" Click="OnApplyBoundsClicked"/>
            </StackPanel>
          </Border>

          <Border BorderBrush="{DynamicResource PanelBorderStrong}" BorderThickness="1" CornerRadius="6" Padding="10" Background="{DynamicResource SurfaceDark}">
            <StackPanel Spacing="8">
              <TextBlock Text="{DynamicResource Ui.MapPack.Step.BaseLayers}" Classes="sectionHeader"/>
              <WrapPanel>
                <CheckBox Content="{DynamicResource Ui.MapPack.Layer.Osm}" IsChecked="{Binding IncludeOsm}" Margin="0,0,12,6"/>
                <CheckBox Content="{DynamicResource Ui.MapPack.Layer.Terrain}" IsChecked="{Binding IncludeTerrain}" Margin="0,0,12,6"/>
                <CheckBox Content="{DynamicResource Ui.MapPack.Layer.Satellite}" IsChecked="{Binding IncludeSatellite}" Margin="0,0,12,6"/>
                <CheckBox Content="{DynamicResource Ui.MapPack.Layer.Contours}" IsChecked="{Binding IncludeContours}" Margin="0,0,12,6"/>
                <CheckBox Content="{DynamicResource Ui.MapPack.Layer.UltraFineContours}" IsChecked="{Binding IncludeUltraFineContours}" IsEnabled="{Binding IncludeContours}" Margin="0,0,12,6"/>
              </WrapPanel>
              <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="4">
                <TextBlock Text="{DynamicResource Ui.MapPack.MinZoom}" Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock Grid.Column="1" Text="{DynamicResource Ui.MapPack.MaxZoom}" Foreground="{DynamicResource TextPrimary}"/>
                <ComboBox Grid.Row="1" ItemsSource="{Binding AvailableZoomLevels}" SelectedItem="{Binding MinimumZoom}"/>
                <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding AvailableZoomLevels}" SelectedItem="{Binding MaximumZoom}"/>
              </Grid>
            </StackPanel>
          </Border>

          <Border BorderBrush="{DynamicResource PanelBorderStrong}" BorderThickness="1" CornerRadius="6" Padding="10" Background="{DynamicResource SurfaceDark}">
            <StackPanel Spacing="8">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="{DynamicResource Ui.MapPack.Step.Poi}" Classes="sectionHeader"/>
                <CheckBox Grid.Column="1" Content="{DynamicResource Ui.MapPack.EnablePoi}" IsChecked="{Binding EnablePoiSeparation}"/>
              </Grid>
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" IsEnabled="{Binding EnablePoiSeparation}">
                <TextBox Text="{Binding PbfPath, UpdateSourceTrigger=PropertyChanged}" Watermark="{DynamicResource Ui.MapPack.PbfPathWatermark}"/>
                <Button Grid.Column="1" Content="{DynamicResource Ui.MapPack.PickPbf}" Click="OnPickPbfClicked"/>
              </Grid>
              <WrapPanel IsEnabled="{Binding EnablePoiSeparation}">
                <CheckBox Content="{DynamicResource Ui.MapPack.GeneratePois}" IsChecked="{Binding GenerateFullPoisJsonl}" Margin="0,0,12,6"/>
                <CheckBox Content="{DynamicResource Ui.MapPack.GenerateTileIndex}" IsChecked="{Binding GenerateTileIndex}" Margin="0,0,12,6"/>
                <CheckBox Content="{DynamicResource Ui.MapPack.Labels}" IsChecked="{Binding IncludePoiLabels}" Margin="0,0,12,6"/>
                <CheckBox Content="{DynamicResource Ui.MapPack.OriginalOsmTags}" IsChecked="{Binding IncludeOriginalOsmTags}" Margin="0,0,12,6"/>
                <CheckBox Content="{DynamicResource Ui.MapPack.PreviewOverlay}" IsChecked="{Binding ShowPoiPreview}" Margin="0,0,12,6"/>
              </WrapPanel>
              <Grid ColumnDefinitions="*,*,*,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="4" IsEnabled="{Binding EnablePoiSeparation}">
                <TextBlock Text="{DynamicResource Ui.MapPack.PoiMinZoom}" Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock Grid.Column="1" Text="{DynamicResource Ui.MapPack.PoiMaxZoom}" Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock Grid.Column="2" Text="{DynamicResource Ui.MapPack.MaxPerTile}" Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock Grid.Column="3" Text="{DynamicResource Ui.MapPack.PreviewLimit}" Foreground="{DynamicResource TextPrimary}"/>
                <ComboBox Grid.Row="1" ItemsSource="{Binding AvailablePoiZoomLevels}" SelectedItem="{Binding PoiIndexMinimumZoom}"/>
                <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding AvailablePoiZoomLevels}" SelectedItem="{Binding PoiIndexMaximumZoom}"/>
                <NumericUpDown Grid.Row="1" Grid.Column="2" Minimum="1" Maximum="5000" Increment="25" Value="{Binding MaxPoiPerTile}"/>
                <NumericUpDown Grid.Row="1" Grid.Column="3" Minimum="1" Maximum="5000" Increment="100" Value="{Binding PoiPreviewLimit}"/>
              </Grid>
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" IsEnabled="{Binding EnablePoiSeparation}">
                <TextBlock Text="{DynamicResource Ui.MapPack.OutputFormat}" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding AvailablePoiOutputFormats}" SelectedItem="{Binding SelectedPoiOutputFormat}" Width="160">
                  <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:PoiOutputFormatOptionViewModel">
                      <TextBlock Text="{Binding Label}"/>
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </Grid>
              <ItemsControl ItemsSource="{Binding PoiTypes}" IsEnabled="{Binding EnablePoiSeparation}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:PoiTypeOptionViewModel">
                    <CheckBox Content="{Binding Label}" IsChecked="{Binding IsSelected}" Margin="0,0,12,6"/>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="{DynamicResource Ui.MapPack.LoadPoiPreview}" Command="{Binding LoadPoiPreviewCommand}"/>
                <TextBlock Text="{Binding PreviewPoiCountText}" Foreground="{DynamicResource TextDim}" VerticalAlignment="Center"/>
              </StackPanel>
            </StackPanel>
          </Border>

          <Border BorderBrush="{DynamicResource PanelBorderStrong}" BorderThickness="1" CornerRadius="6" Padding="10" Background="{DynamicResource SurfaceDark}">
            <StackPanel Spacing="8">
              <TextBlock Text="{DynamicResource Ui.MapPack.Step.Estimate}" Classes="sectionHeader"/>
              <Button Content="{DynamicResource Ui.MapPack.RefreshEstimate}" HorizontalAlignment="Left" Command="{Binding EstimateCommand}"/>
              <TextBlock Text="{Binding EstimateText}" Foreground="{DynamicResource TextDim}" TextWrapping="Wrap"/>
            </StackPanel>
          </Border>

          <Border BorderBrush="{DynamicResource PanelBorderStrong}" BorderThickness="1" CornerRadius="6" Padding="10" Background="{DynamicResource SurfaceDark}">
            <StackPanel Spacing="8">
              <TextBlock Text="{DynamicResource Ui.MapPack.Step.Export}" Classes="sectionHeader"/>
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox Text="{Binding OutputDirectory, UpdateSourceTrigger=PropertyChanged}" Watermark="{DynamicResource Ui.MapPack.OutputWatermark}"/>
                <Button Grid.Column="1" Content="{DynamicResource Ui.MapPack.PickFolder}" Click="OnPickOutputFolderClicked"/>
              </Grid>
              <TextBlock Text="{DynamicResource Ui.MapPack.ExportHint}"
                         Classes="dialogHint"
                         TextWrapping="Wrap"/>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <Border Grid.Row="2" BorderBrush="{DynamicResource PanelBorder}" BorderThickness="0,1,0,0" Padding="0,10,0,0">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Spacing="4">
            <ProgressBar Minimum="0"
                         Maximum="100"
                         Height="8"
                         Value="{Binding ExportProgressPercent}"
                         IsIndeterminate="{Binding IsExportProgressIndeterminate}"
                         IsVisible="{Binding HasExportProgress}"/>
            <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource TextDim}" TextWrapping="Wrap"/>
            <TextBlock Text="{Binding OutputDirectory}" Foreground="{DynamicResource TextDim}" FontSize="10" TextWrapping="Wrap"/>
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
            <Button Content="{DynamicResource Ui.MapPack.CancelTask}" Command="{Binding CancelCommand}" IsEnabled="{Binding IsBusy}"/>
            <Button Content="{DynamicResource Ui.MapPack.Close}" Click="OnCloseClicked"/>
            <Button Content="{DynamicResource Ui.MapPack.ExportMapPack}" Classes="primary" IsEnabled="{Binding CanExport}" Click="OnExportClicked"/>
          </StackPanel>
        </Grid>
      </Border>
    </Grid>
  </Border>
</Window>
